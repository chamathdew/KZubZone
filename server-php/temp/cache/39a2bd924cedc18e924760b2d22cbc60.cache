e.tmdb.org\/t\/p\/original\/zs803kZR1rT5niAakQokxtp3Uqv.jpg","https:\/\/image.tmdb.org\/t\/p\/original\/8GdL6o4zzSAJmHy5ZwWwTDLwXS1.jpg","https:\/\/image.tmdb.org\/t\/p\/original\/isOBmIuaPrJ29QWYgRQuOY3Fsdi.jpg"],"poster":"https:\/\/image.tmdb.org\/t\/p\/w500\/ozuyMnOO5pekDklyPpUL1Htkuzy.jpg","status":"Draft","studio":"Studio Dragon","tmdbId":108261,"country":"KR","runtime":60,"trailer":"https:\/\/www.youtube.com\/embed\/dImREPX_Pbk","writers":["Park Kye-ok","Choi A-il"],"director":"Yun Seong-sik","keywords":["time travel","transmigration","body-swap","power struggle","joseon dynasty (1392\u20131910)","gender swap","witty"],"language":"ko","backdrops":["https:\/\/image.tmdb.org\/t\/p\/original\/zs803kZR1rT5niAakQokxtp3Uqv.jpg"],"metaTitle":"Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 (2020) Sinhala & English Subtitles | KSubZone","viewCount":49,"imdbRating":8.499,"isTrending":false,"tmdbRating":8.499,"description":"Modern age \u0d91\u0d9a\u0dda Jang Bong-hwan (Choi Jin-hyuk) Blue House \u0d91\u0d9a\u0dda Head Chef \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dd2\u0dc4\u0da7 \u0dc0\u0dd0\u0da9 \u0d9a\u0dbb\u0db1\u0dc0\u0dcf. Freedom-loving, womanizer character \u0d91\u0d9a\u0d9a\u0dca \u0dc0\u0db1 \u0d94\u0dc4\u0dd4, Chinese delegate \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0d94\u0dc4\u0dd4 \u0dc4\u0daf\u0db4\u0dd4 food \u0d91\u0d9a\u0d9a\u0dca \u0d9a\u0daf\u0dca\u0daf\u0dd3 fish hook \u0d91\u0d9a\u0d9a\u0dca \u0dc4\u0db8\u0dca\u0db6\u0dc0\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dbd\u0ddc\u0d9a\u0dd4 trouble \u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dca\u0dc3\u0dda near-death experience \u0d91\u0d9a\u0d9a\u0dca \u0dc3\u0db8\u0d9f pool \u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd9\u0db1 Bong-hwan, \u0d87\u0dc3\u0dca \u0d87\u0dbb\u0dd2\u0dba\u0db8 \u0dad\u0db8\u0db1\u0dca Joseon era \u0d91\u0d9a\u0dda Queen Cheorin (Shin Hye-sun) \u0d9c\u0dda body \u0d91\u0d9a \u0d87\u0dad\u0dd4\u0dc5\u0dda \u0d89\u0db1\u0dca\u0db1 \u0db6\u0dc0 \u0daf\u0dd0\u0db1\u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf.\n\nJoseon \u0dbb\u0dcf\u0da2\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dda King Cheoljong (Kim Jung-hyun) \u0db1\u0db8\u0dca \u0db8\u0dd8\u0daf\u0dd4 \u0dc3\u0dc4 easy-going king \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0d9c\u0dda \u0db4\u0dda\u0db1\u0dc0\u0dcf. \u0dc4\u0dd0\u0db6\u0dd0\u0dba\u0dd2 \u0d87\u0dad\u0dca\u0dad power \u0d91\u0d9a \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda late King Sunjo \u0d9c\u0dda widow \u0dc0\u0db1 Queen Sunwon (Bae Jong-ok) \u0d85\u0dad\u0dda. \u0dad\u0db8\u0db1\u0dca\u0d9c\u0dda modern body \u0d91\u0d9a\u0da7 \u0d86\u0db4\u0dc4\u0dd4 \u0dba\u0db1\u0dca\u0db1 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dbb\u0db1 Bong-hwan, Queen Sunwon \u0d9c\u0dda favor \u0d91\u0d9a \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0db1\u0dca\u0db1 cooking skills \u0db4\u0dc0\u0dcf \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb\u0db1\u0dc0\u0dcf.\n\n\u0db1\u0db8\u0dd4\u0dad\u0dca \u0d9a\u0dcf\u0dbd\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0d94\u0dc4\u0dd4 So-yong \u0dc3\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0dbb\u0dc4\u0dc3\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0d9c\u0dd0\u0db1 \u0daf\u0dd0\u0db1\u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf. \u0d92 \u0dc0\u0d9c\u0dda\u0db8, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc4\u0dcf \u0d85\u0dc4\u0dd2\u0d82\u0dc3\u0d9a king \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0d9c\u0dda \u0db4\u0dd9\u0db1\u0dd9\u0db1 Cheoljong \u0d87\u0dad\u0dca\u0dad\u0da7\u0db8 \u0d91\u0dc4\u0dd9\u0db8 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0d94\u0dc4\u0dd4\u0d9c\u0dda dark \u0dc4\u0dcf mysterious side \u0d91\u0d9a\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc4\u0dd9\u0dc5\u0dd2 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf.\n\nComedy, Romance, Fantasy \u0dc3\u0dc4 Political Intrigue \u0d91\u0d9a\u0da7 \u0d91\u0d9a\u0dad\u0dd4 \u0d9a\u0dbb\u0db4\u0dd4 \u0db8\u0dda drama \u0d91\u0d9a, modern man's soul \u0d91\u0d9a\u0d9a\u0dca Joseon Queen \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0d9c\u0dda body \u0d91\u0d9a \u0dad\u0dd4\u0dc5 \u0dc3\u0dd2\u0dbb\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d87\u0dad\u0dd2\u0dc0\u0db1 hilarious situations \u0dc3\u0dc4 unexpected twists \u0dbb\u0dd0\u0dc3\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dc0\u0dcf.\n","releaseDate":"2020-12-12","seoKeywords":["mr. queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","mr. queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 sinhala subtitles","mr. queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 subtitles","mr. queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 eng sub","ksubzone mr. queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","korean entertainment","ksubzone","time travel","transmigration","body-swap","power struggle","joseon dynasty (1392\u20131910)","gender swap","witty"],"castOverview":"The performance of \"Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" is anchored by Shin Hae-sun, Kim Jung-hyun, Bae Jong-ok. The chemistry between the lead actors creates an intense atmosphere, making every dramatic encounter resonate with viewers. Critical reception has highlighted their versatility in these roles.","isHistorical":false,"schemaMarkup":{"url":"https:\/\/www.ksubzone.com\/drama\/mr-queen-2020-","name":"Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","@type":"TVSeries","genre":["time travel","transmigration","body-swap","power struggle","joseon dynasty (1392\u20131910)","gender swap","witty"],"@context":"https:\/\/schema.org","startDate":"2020-12-12","description":"Modern age \u0d91\u0d9a\u0dda Jang Bong-hwan (Choi Jin-hyuk) Blue House \u0d91\u0d9a\u0dda Head Chef \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dd2\u0dc4\u0da7 \u0dc0\u0dd0\u0da9 \u0d9a\u0dbb\u0db1\u0dc0\u0dcf. Freedom-loving, womanizer character \u0d91\u0d9a\u0d9a\u0dca \u0dc0\u0db1 \u0d94\u0dc4\u0dd4, Chinese delegate \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0d94\u0dc4\u0dd4 \u0dc4\u0daf\u0db4\u0dd4 food \u0d91\u0d9a\u0d9a\u0dca \u0d9a\u0daf\u0dca\u0daf\u0dd3 fish hook \u0d91\u0d9a\u0d9a\u0dca \u0dc4\u0db8\u0dca\u0db6\u0dc0\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dbd\u0ddc\u0d9a\u0dd4 trouble \u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dca\u0dc3\u0dda near-death experience \u0d91\u0d9a\u0d9a\u0dca \u0dc3\u0db8\u0d9f pool \u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd9\u0db1 Bong-hwan, \u0d87\u0dc3\u0dca \u0d87\u0dbb\u0dd2\u0dba\u0db8 \u0dad\u0db8\u0db1\u0dca Joseon era \u0d91\u0d9a\u0dda Queen Cheorin (Shin Hye-sun) \u0d9c\u0dda body \u0d91\u0d9a \u0d87\u0dad\u0dd4\u0dc5\u0dda \u0d89\u0db1\u0dca\u0db1 \u0db6\u0dc0 \u0daf\u0dd0\u0db1\u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf.\n\nJoseon \u0dbb\u0dcf\u0da2\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dda King Cheoljong (Kim Jung-hyun) \u0db1\u0db8\u0dca \u0db8\u0dd8\u0daf\u0dd4 \u0dc3\u0dc4 easy-going king \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0d9c\u0dda \u0db4\u0dda\u0db1\u0dc0\u0dcf. \u0dc4\u0dd0\u0db6\u0dd0\u0dba\u0dd2 \u0d87\u0dad\u0dca\u0dad power \u0d91\u0d9a \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda late King Sunjo \u0d9c\u0dda widow \u0dc0\u0db1 Queen Sunwon (Bae Jong-ok) \u0d85\u0dad\u0dda. \u0dad\u0db8\u0db1\u0dca\u0d9c\u0dda modern body \u0d91\u0d9a\u0da7 \u0d86\u0db4\u0dc4\u0dd4 \u0dba\u0db1\u0dca\u0db1 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dbb\u0db1 Bong-hwan, Queen Sunwon \u0d9c\u0dda favor \u0d91\u0d9a \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0db1\u0dca\u0db1 cooking skills \u0db4\u0dc0\u0dcf \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb\u0db1\u0dc0\u0dcf.\n\n\u0db1\u0db8\u0dd4\u0dad\u0dca \u0d9a\u0dcf\u0dbd\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0d94\u0dc4\u0dd4 So-yong \u0dc3\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0dbb\u0dc4\u0dc3\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0d9c\u0dd0\u0db1 \u0daf\u0dd0\u0db1\u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf. \u0d92 \u0dc0\u0d9c\u0dda\u0db8, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc4\u0dcf \u0d85\u0dc4\u0dd2\u0d82\u0dc3\u0d9a king \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0d9c\u0dda \u0db4\u0dd9\u0db1\u0dd9\u0db1 Cheoljong \u0d87\u0dad\u0dca\u0dad\u0da7\u0db8 \u0d91\u0dc4\u0dd9\u0db8 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0d94\u0dc4\u0dd4\u0d9c\u0dda dark \u0dc4\u0dcf mysterious side \u0d91\u0d9a\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc4\u0dd9\u0dc5\u0dd2 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf.\n\nComedy, Romance, Fantasy \u0dc3\u0dc4 Political Intrigue \u0d91\u0d9a\u0da7 \u0d91\u0d9a\u0dad\u0dd4 \u0d9a\u0dbb\u0db4\u0dd4 \u0db8\u0dda drama \u0d91\u0d9a, modern man's soul \u0d91\u0d9a\u0d9a\u0dca Joseon Queen \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0d9c\u0dda body \u0d91\u0d9a \u0dad\u0dd4\u0dc5 \u0dc3\u0dd2\u0dbb\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d87\u0dad\u0dd2\u0dc0\u0db1 hilarious situations \u0dc3\u0dc4 unexpected twists \u0dbb\u0dd0\u0dc3\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dc0\u0dcf.\n"},"originalTitle":"\ucca0\uc778\uc655\ud6c4","storyOverview":"The plot of \"Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" delves deeply into complex themes. Under the guidance of director Yun Seong-sik, the narrative avoids standard clich\u00e9s to explore the psychological motives of its protagonists. The thematic backdrop of time travel, transmigration, body-swap, power struggle, joseon dynasty (1392\u20131910), gender swap, witty elements adds a rich atmosphere to the entire run.","seriesOverview":"\"Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" has established itself as a landmark TV Series. Composed of multiple seasons and episodes, the drama features structural storylines that keep audiences returning week after week.","metaDescription":"Download Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 (2020) Sinhala and English subtitles in SRT, VTT, or ASS format. Read comments, casting breakdowns, and the full storyline FAQs.","synopsisRewrite":"In a captivating narrative spin, \"Mr. Queen (2020) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" presents a powerful storyline. Modern age \u0d91\u0d9a\u0dda Jang Bong-hwan (Choi Jin-hyuk) Blue House \u0d91\u0d9a\u0dda Head Chef \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dd2\u0dc4\u0da7 \u0dc0\u0dd0\u0da9 \u0d9a\u0dbb\u0db1\u0dc0\u0dcf. Freedom-loving, womanizer character \u0d91\u0d9a\u0d9a\u0dca \u0dc0\u0db1 \u0d94\u0dc4\u0dd4, Chinese delegate \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0d94\u0dc4\u0dd4 \u0dc4\u0daf\u0db4\u0dd4 food \u0d91\u0d9a\u0d9a\u0dca \u0d9a\u0daf\u0dca\u0daf\u0dd3 fish hook \u0d91\u0d9a\u0d9a\u0dca \u0dc4\u0db8\u0dca\u0db6\u0dc0\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dbd\u0ddc\u0d9a\u0dd4 trouble \u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dca\u0dc3\u0dda near-death experience \u0d91\u0d9a\u0d9a\u0dca \u0dc3\u0db8\u0d9f pool \u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd9\u0db1 Bong-hwan, \u0d87\u0dc3\u0dca \u0d87\u0dbb\u0dd2\u0dba\u0db8 \u0dad\u0db8\u0db1\u0dca Joseon era \u0d91\u0d9a\u0dda Queen Cheorin (Shin Hye-sun) \u0d9c\u0dda body \u0d91\u0d9a \u0d87\u0dad\u0dd4\u0dc5\u0dda \u0d89\u0db1\u0dca\u0db1 \u0db6\u0dc0 \u0daf\u0dd0\u0db1\u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf.\n\nJoseon \u0dbb\u0dcf\u0da2\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dda King Cheoljong (Kim Jung-hyun) \u0db1\u0db8\u0dca \u0db8\u0dd8\u0daf\u0dd4 \u0dc3\u0dc4 easy-going king \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0d9c\u0dda \u0db4\u0dda\u0db1\u0dc0\u0dcf. \u0dc4\u0dd0\u0db6\u0dd0\u0dba\u0dd2 \u0d87\u0dad\u0dca\u0dad power \u0d91\u0d9a \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda late King Sunjo \u0d9c\u0dda widow \u0dc0\u0db1 Queen Sunwon (Bae Jong-ok) \u0d85\u0dad\u0dda. \u0dad\u0db8\u0db1\u0dca\u0d9c\u0dda modern body \u0d91\u0d9a\u0da7 \u0d86\u0db4\u0dc4\u0dd4 \u0dba\u0db1\u0dca\u0db1 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dbb\u0db1 Bong-hwan, Queen Sunwon \u0d9c\u0dda favor \u0d91\u0d9a \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0db1\u0dca\u0db1 cooking skills \u0db4\u0dc0\u0dcf \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb\u0db1\u0dc0\u0dcf.\n\n\u0db1\u0db8\u0dd4\u0dad\u0dca \u0d9a\u0dcf\u0dbd\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0d94\u0dc4\u0dd4 So-yong \u0dc3\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0dbb\u0dc4\u0dc3\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0d9c\u0dd0\u0db1 \u0daf\u0dd0\u0db1\u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf. \u0d92 \u0dc0\u0d9c\u0dda\u0db8, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc4\u0dcf \u0d85\u0dc4\u0dd2\u0d82\u0dc3\u0d9a king \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc0\u0d9c\u0dda \u0db4\u0dd9\u0db1\u0dd9\u0db1 Cheoljong \u0d87\u0dad\u0dca\u0dad\u0da7\u0db8 \u0d91\u0dc4\u0dd9\u0db8 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0d94\u0dc4\u0dd4\u0d9c\u0dda dark \u0dc4\u0dcf mysterious side \u0d91\u0d9a\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc4\u0dd9\u0dc5\u0dd2 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf.\n\nComedy, Romance, Fantasy \u0dc3\u0dc4 Political Intrigue \u0d91\u0d9a\u0da7 \u0d91\u0d9a\u0dad\u0dd4 \u0d9a\u0dbb\u0db4\u0dd4 \u0