w6b3nMmebZZsDB.jpg","https:\/\/image.tmdb.org\/t\/p\/original\/8QQVhPDXq4sq1okljROqKZvyKPG.jpg","https:\/\/image.tmdb.org\/t\/p\/original\/2G0NV6KF2pX1B9vqGzdz77gwpcK.jpg"],"poster":"https:\/\/image.tmdb.org\/t\/p\/w500\/rYLQbyIvbEd0lF84iXrx7CbPcBB.jpg","status":"Published","studio":"Studio S","tmdbId":303143,"country":"KR","runtime":60,"trailer":"https:\/\/www.youtube.com\/embed\/tPAHynPDHbo","writers":["Kang Hyun-joo"],"director":"Han Tae-seob","keywords":["time travel","reincarnation","supernatural","romcom","rivalry","romance","villainess","possessed","transmigration","rich family","joseon dynasty (1392\u20131910)","historical comedy","enemies to lovers","yearning","fantasy","actress","chaebol","past and present","identity confusion","spirit possession","cursed love"],"language":"ko","backdrops":["https:\/\/image.tmdb.org\/t\/p\/original\/p1ntnKJwn1URGv1xpU6NN33Y11O.jpg"],"metaTitle":"My Royal Nemesis (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 (2026) Sinhala & English Subtitles | KSubZone","viewCount":760,"imdbRating":9.1,"isTrending":true,"tmdbRating":9.1,"description":"Joseon dynasty \u0dc3\u0db8\u0dba\u0dda\u0daf\u0dd3, Kang Dan-shim \u0d9a\u0dd2\u0dba\u0db1\u0dca\u0db1\u0dda court \u0d91\u0d9a \u0dad\u0dd4\u0dc5 \u0d89\u0dad\u0dcf\u0db8 cunning, intelligent \u0dc3\u0dc4 ambitious \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca. \u0d87\u0dba \u0dad\u0db8 \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2\u0dba \u0dc3\u0dc4 manipulation skills \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca royal court \u0d91\u0d9a\u0dda \u0db6\u0dbd\u0dba gradually \u0d85\u0dbd\u0dca\u0dbd\u0dcf\u0d9c\u0dd9\u0db1 royal concubine \u0dad\u0db1\u0dad\u0dd4\u0dbb \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d8b\u0dc3\u0dc3\u0dca \u0dc0\u0dd9\u0dba\u0dd2.\n\n\u0db1\u0db8\u0dd4\u0dad\u0dca King Anjong\u0d9c\u0dda \u0db4\u0dcf\u0dbd\u0db1 6 \u0dc0\u0db1 \u0dc0\u0dc3\u0dbb\u0dda\u0daf\u0dd3, court politics \u0dc3\u0dc4 jealousy \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d87\u0dba\u0da7 \u0db6\u0dbd\u0dc4\u0dad\u0dca\u0d9a\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca poison bowl \u0d91\u0d9a\u0d9a\u0dca \u0db4\u0dcf\u0db1\u0dba \u0d9a\u0dbb\u0dc0\u0dbd\u0dcf \u0db8\u0dbb\u0dab\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0d87\u0d9c\u0dda \u0db8\u0dbb\u0dab\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9f\u0db8, \u0d85\u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba supernatural events \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dd9\u0dba\u0dd2 \u2014 midsummer \u0d91\u0d9a\u0dda\u0daf\u0dd3 \u0d85\u0db8\u0dd4\u0dad\u0dd4 frost, \u0dc3\u0dc4 \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab lunar eclipse \u0d91\u0d9a\u0d9a\u0dca \u0db4\u0dc0\u0dcf \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd9\u0dba\u0dd2.\n\n\u0db1\u0db8\u0dd4\u0dad\u0dca Dan-shim\u0d9c\u0dda \u0d9a\u0dad\u0dcf\u0dc0 \u0d91\u0dad\u0dd0\u0db1\u0dd2\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dc4\u0dd0.\n\n\u0d87\u0d9c\u0dda \u0d86\u0dad\u0dca\u0db8\u0dba \u0d85\u0db1\u0dcf\u0d9c\u0dad\u0dba \u0dc0\u0dd9\u0dad \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0dbd\u0dcf 21st-century South Korea \u0d91\u0d9a\u0dda\u0daf\u0dd3 \u0db1\u0dd0\u0dc0\u0dad \u0d85\u0dc0\u0daf\u0dd2 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0d87\u0dba \u0daf\u0dd0\u0db1\u0dca \u0d89\u0db1\u0dca\u0db1\u0dda Shin Seo-ri \u0d9a\u0dd2\u0dba\u0db1 \u0d85\u0da9\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dc3\u0dd2\u0daf\u0dca\u0db0 actress \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0dc1\u0dbb\u0dd3\u0dbb\u0dba \u0dad\u0dd4\u0dc5\u0dba\u0dd2 \u2014 historical dramas \u0dc0\u0dbd minor roles \u0d9a\u0dbb\u0db1 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca.\n\n\u0db8\u0dd4\u0dbd\u0dca \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 Seo-ri\u0d9c\u0dda \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0dad\u0dd4\u0dc5 \u0dc3\u0dd3\u0db8\u0dcf \u0dc0\u0dd6 Dan-shim, \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba\u0dd9\u0db1\u0dca \u0d87\u0d9c\u0dda body \u0d91\u0d9a \u0dc3\u0dc4 identity \u0d91\u0d9a \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0d9a\u0dbb\u0db1\u0dca\u0db1 \u0db4\u0da7\u0db1\u0dca \u0d9c\u0db1\u0dd3. Modern world \u0d91\u0d9a \u0d87\u0dba\u0da7 \u0d85\u0dbd\u0dd4\u0dad\u0dca \u0dc0\u0dd4\u0dab\u0dad\u0dca, \u0d87\u0d9c\u0dda cunning nature \u0d91\u0d9a \u0db1\u0dd2\u0dc3\u0dcf she adapts very quickly.\n\n\u0db8\u0dd9\u0db8 \u0db1\u0dc0 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba\u0dda\u0daf\u0dd3 \u0d87\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda Cha Se-gye \u0db1\u0db8\u0dca ruthless chaebol heir \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca. \u0d94\u0dc4\u0dd4 cold, powerful, and emotionally detached person \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca.\n\n\u0d94\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0d85\u0dad\u0dbb relationship \u0d91\u0d9a:\n\nconstant clashes\nego battles\npower struggles\nbut also undeniable attraction\n\n\u0d92\u0d9a slowly love\u2013hate dynamic \u0d91\u0d9a\u0d9a\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd9\u0dba\u0dd2.\n\nDan-shim \u0daf\u0dd0\u0db1\u0dca \u0dad\u0dda\u0dbb\u0dd4\u0db8\u0dca \u0d9c\u0db1\u0dca\u0db1\u0dc0\u0dcf:\n\u0db8\u0dd9\u0db8 \u0d85\u0dbd\u0dd4\u0dad\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0d9a\u0dd2\u0dba\u0db1\u0dca\u0db1\u0dda punishment \u0d91\u0d9a\u0d9a\u0dca \u0db1\u0dd9\u0dc0\u0dd9\u0dba\u0dd2 \u2014 second chance \u0d91\u0d9a\u0d9a\u0dca.\n\n\u0d87\u0dba\u0da7 \u0db4\u0dd4\u0dc5\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0db8\u0db1\u0dca\u0d9c\u0dda \u0db4\u0dd9\u0dbb fate \u0d91\u0d9a \u0db6\u0dd2\u0db3 \u0daf\u0db8\u0dbd\u0dcf:\n\nhistory \u0d91\u0d9a\u0dd9\u0db1\u0dca escape \u0dc0\u0dd9\u0db1\u0dca\u0db1\nmodern world \u0d91\u0d9a\u0dda identity redefine \u0d9a\u0dbb\u0db1\u0dca\u0db1\n\u0dc3\u0dc4 \u0dad\u0db8 destiny \u0d91\u0d9a control \u0d9a\u0dbb\u0db1\u0dca\u0db1","releaseDate":"2026-05-08","seoKeywords":["my royal nemesis (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","my royal nemesis (2026) \u0dc3\u0dd2\u0d8