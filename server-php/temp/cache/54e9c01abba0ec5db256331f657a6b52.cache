u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0da7 \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dd3\u0dba \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f\u0dba\u0dd2. \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d85\u0dad\u0dbb\u0dd2\u0db1\u0dca Ga Ui-su \u0dba\u0db1\u0dd4 \u0d85\u0dad\u0dd3\u0dad\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dc4\u0dd2\u0dad \u0d85\u0dad\u0dd2\u0daf\u0d9a\u0dca\u0dc2 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd2. Noh Da-ju \u0dba\u0db1\u0dd4 \u0db7\u0dcf\u0dc2\u0dcf \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0daf\u0db1\u0dca\u0db1\u0dcf \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dd3\u0dba \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0d94\u0dc4\u0dd4 Ui-su\u0d9c\u0dda \u0d9a\u0dd4\u0da9\u0dcf \u0d9a\u0dbd \u0dc3\u0dd2\u0da7\u0db8 \u0dc3\u0db8\u0dd3\u0db4 \u0db8\u0dd2\u0dad\u0dd4\u0dbb\u0dd9\u0d9a\u0dd2. Jung Gi-jeon \u0dba\u0db1\u0dd4 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dc0\u0db1\u0dca\u0dad \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb Eui-ju\u0d9c\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0daf\u0d9a\u0dca\u0dc2\u0dad\u0dcf \u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0dba. Yoon Dong-ju \u0db1\u0db8\u0dca \u0d9a\u0ddc\u0dbb\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dc3\u0dcf\u0dc4\u0dd2\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dba\u0dcf \u0dc3\u0db1\u0dca\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0d9c\u0dde\u0dbb\u0dc0\u0dcf\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0dc4\u0dd0\u0dc3\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0d9a\u0dca\u0dad\u0dba.\n\nEui-ju \u0db8\u0dd9\u0db8 \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dcf\u0db8 \u0dad\u0db8 \u0db1\u0dc0 \u0d86\u0daf\u0dbb \u0d9a\u0dad\u0dcf\u0dc0\u0dda \u0da0\u0dbb\u0dd2\u0dad \u0dbd\u0dd9\u0dc3 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb, \u0d87\u0dba\u0d9c\u0dda \u0db4\u0dd4\u0daf\u0dd4\u0db8\u0dba\u0da7 \u0d91\u0db8 \u0db1\u0dc0\u0d9a\u0dad\u0dcf\u0dc0 \u0d85\u0dad\u0dd2\u0dc1\u0dba \u0da2\u0db1\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba \u0dc0\u0dd9\u0dba\u0dd2. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0d87\u0dba\u0d9c\u0dda \u0dbd\u0ddc\u0d9a\u0dd4\u0db8 \u0dc3\u0dad\u0dd4\u0dbb\u0dcf \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dad\u0db1 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0db1 Ui-su \u0d87\u0dba\u0d9c\u0dda \u0dbb\u0dc4\u0dc3 \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0db1\u0dd3. \u0d94\u0dc4\u0dd4 \u0db1\u0dd2\u0dc4\u0dac\u0dc0 \u0dc3\u0dd2\u0da7\u0dd3\u0db8 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0d9a\u0da7 \u0d87\u0dba \u0d91\u0d9a\u0d9f \u0dc0\u0dd4\u0dc0\u0daf, \u0da2\u0db1\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0db8\u0d9f\u0db8 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd9\u0daf\u0dbb \u0dc0\u0dd0\u0da9 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0dad\u0dca, \u0d87\u0dba\u0d9c\u0dda \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0dc3\u0db8\u0db6\u0dbb\u0dc0 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0dad\u0dca \u0d87\u0dba\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd9\u0dba\u0dd2.","releaseDate":"2026-04-17","seoKeywords":["absolute value of romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","absolute value of romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 sinhala subtitles","absolute value of romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 subtitles","absolute value of romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 eng sub","ksubzone absolute value of romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","korean entertainment","ksubzone","romcom","teacher student relationship","high school girl","youth","school setting"],"castOverview":"The performance of \"Absolute Value of Romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" is anchored by Kim Hyang-gi, Cha Hak-yeon, Kim Jae-hyun. The chemistry between the lead actors creates an intense atmosphere, making every dramatic encounter resonate with viewers. Critical reception has highlighted their versatility in these roles.","isHistorical":false,"schemaMarkup":{"url":"https:\/\/www.ksubzone.com\/drama\/absolute-value-of-romance-2026-","name":"Absolute Value of Romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2","@type":"TVSeries","genre":["romcom","teacher student relationship","high school girl","youth","school setting"],"@context":"https:\/\/schema.org","startDate":"2026-04-17","description":"Yeo Eui-ju \u0d9a\u0dd2\u0dba\u0db1\u0dca\u0db1\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0daf\u0dd9\u0dc0\u0db1 \u0dc0\u0dc3\u0dbb\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dd2\u0dba\u0d9a\u0dca. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0dbb\u0dc4\u0dc3\u0dd2\u0db1\u0dca \u0d87\u0dba BL web novels \u0dbd\u0dd2\u0dba\u0db1 \u0dbd\u0dda\u0d9b\u0dd2\u0d9a\u0dcf\u0dc0\u0d9a\u0dca\u0daf \u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0d87\u0dba \u0dbd\u0dd2\u0dba\u0db1 \u0d9a\u0dad\u0dcf episode 100\u0d9a\u0dca \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0dc5 \u0dc0\u0dd4\u0dab\u0dad\u0dca \u0d92\u0dc0\u0dcf\u0da7 \u0dbd\u0dd0\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db6\u0dbd\u0db1\u0dca\u0db1\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7\u0dad\u0dca \u0d85\u0da9\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dd2. \u0d91\u0dc4\u0dd9\u0dad\u0dca \u0d91\u0d9a\u0dca \u0daf\u0dd2\u0db1\u0d9a \u0d87\u0dba\u0d9c\u0dda \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0dc0\u0dd9\u0db1\u0dc3\u0dca \u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0da7 \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dd3\u0dba \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f\u0dba\u0dd2. \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d85\u0dad\u0dbb\u0dd2\u0db1\u0dca Ga Ui-su \u0dba\u0db1\u0dd4 \u0d85\u0dad\u0dd3\u0dad\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dc4\u0dd2\u0dad \u0d85\u0dad\u0dd2\u0daf\u0d9a\u0dca\u0dc2 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd2. Noh Da-ju \u0dba\u0db1\u0dd4 \u0db7\u0dcf\u0dc2\u0dcf \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0daf\u0db1\u0dca\u0db1\u0dcf \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dd3\u0dba \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0d94\u0dc4\u0dd4 Ui-su\u0d9c\u0dda \u0d9a\u0dd4\u0da9\u0dcf \u0d9a\u0dbd \u0dc3\u0dd2\u0da7\u0db8 \u0dc3\u0db8\u0dd3\u0db4 \u0db8\u0dd2\u0dad\u0dd4\u0dbb\u0dd9\u0d9a\u0dd2. Jung Gi-jeon \u0dba\u0db1\u0dd4 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dc0\u0db1\u0dca\u0dad \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb Eui-ju\u0d9c\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0daf\u0d9a\u0dca\u0dc2\u0dad\u0dcf \u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0dba. Yoon Dong-ju \u0db1\u0db8\u0dca \u0d9a\u0ddc\u0dbb\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dc3\u0dcf\u0dc4\u0dd2\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dba\u0dcf \u0dc3\u0db1\u0dca\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0d9c\u0dde\u0dbb\u0dc0\u0dcf\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0dc4\u0dd0\u0dc3\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0d9a\u0dca\u0dad\u0dba.\n\nEui-ju \u0db8\u0dd9\u0db8 \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dcf\u0db8 \u0dad\u0db8 \u0db1\u0dc0 \u0d86\u0daf\u0dbb \u0d9a\u0dad\u0dcf\u0dc0\u0dda \u0da0\u0dbb\u0dd2\u0dad \u0dbd\u0dd9\u0dc3 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb, \u0d87\u0dba\u0d9c\u0dda \u0db4\u0dd4\u0daf\u0dd4\u0db8\u0dba\u0da7 \u0d91\u0db8 \u0db1\u0dc0\u0d9a\u0dad\u0dcf\u0dc0 \u0d85\u0dad\u0dd2\u0dc1\u0dba \u0da2\u0db1\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba \u0dc0\u0dd9\u0dba\u0dd2. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0d87\u0dba\u0d9c\u0dda \u0dbd\u0ddc\u0d9a\u0dd4\u0db8 \u0dc3\u0dad\u0dd4\u0dbb\u0dcf \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dad\u0db1 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0db1 Ui-su \u0d87\u0dba\u0d9c\u0dda \u0dbb\u0dc4\u0dc3 \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0db1\u0dd3. \u0d94\u0dc4\u0dd4 \u0db1\u0dd2\u0dc4\u0dac\u0dc0 \u0dc3\u0dd2\u0da7\u0dd3\u0db8 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0d9a\u0da7 \u0d87\u0dba \u0d91\u0d9a\u0d9f \u0dc0\u0dd4\u0dc0\u0daf, \u0da2\u0db1\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0db8\u0d9f\u0db8 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd9\u0daf\u0dbb \u0dc0\u0dd0\u0da9 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0dad\u0dca, \u0d87\u0dba\u0d9c\u0dda \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0dc3\u0db8\u0db6\u0dbb\u0dc0 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0dad\u0dca \u0d87\u0dba\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd9\u0dba\u0dd2."},"originalTitle":"\ub85c\ub9e8\uc2a4\uc758 \uc808\ub313\uac12","storyOverview":"The plot of \"Absolute Value of Romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" delves deeply into complex themes. Under the guidance of director Lee Tae-gon, the narrative avoids standard clich\u00e9s to explore the psychological motives of its protagonists. The thematic backdrop of romcom, teacher student relationship, high school girl, youth, school setting elements adds a rich atmosphere to the entire run.","seriesOverview":"\"Absolute Value of Romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" has established itself as a landmark TV Series. Composed of multiple seasons and episodes, the drama features structural storylines that keep audiences returning week after week.","metaDescription":"Download Absolute Value of Romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2 (2026) Sinhala and English subtitles in SRT, VTT, or ASS format. Read comments, casting breakdowns, and the full storyline FAQs.","synopsisRewrite":"In a captivating narrative spin, \"Absolute Value of Romance (2026) \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0d8b\u0db4\u0dc3\u0dd2\u0dbb\u0dd0\u0dc3\u0dd2\" presents a powerful storyline. Yeo Eui-ju \u0d9a\u0dd2\u0dba\u0db1\u0dca\u0db1\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0daf\u0dd9\u0dc0\u0db1 \u0dc0\u0dc3\u0dbb\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dd2\u0dba\u0d9a\u0dca. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0dbb\u0dc4\u0dc3\u0dd2\u0db1\u0dca \u0d87\u0dba BL web novels \u0dbd\u0dd2\u0dba\u0db1 \u0dbd\u0dda\u0d9b\u0dd2\u0d9a\u0dcf\u0dc0\u0d9a\u0dca\u0daf \u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0d87\u0dba \u0dbd\u0dd2\u0dba\u0db1 \u0d9a\u0dad\u0dcf episode 100\u0d9a\u0dca \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0dc5 \u0dc0\u0dd4\u0dab\u0dad\u0dca \u0d92\u0dc0\u0dcf\u0da7 \u0dbd\u0dd0\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db6\u0dbd\u0db1\u0dca\u0db1\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7\u0dad\u0dca \u0d85\u0da9\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dd2. \u0d91\u0dc4\u0dd9\u0dad\u0dca \u0d91\u0d9a\u0dca \u0daf\u0dd2\u0db1\u0d9a \u0d87\u0dba\u0d9c\u0dda \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0dc0\u0dd9\u0db1\u0dc3\u0dca \u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0da7 \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dd3\u0dba \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f\u0dba\u0dd2. \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d85\u0dad\u0dbb\u0dd2\u0db1\u0dca Ga Ui-su \u0dba\u0db1\u0dd4 \u0d85\u0dad\u0dd3\u0dad\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dc4\u0dd2\u0dad \u0d85\u0dad\u0dd2\u0daf\u0d9a\u0dca\u0dc2 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd2. Noh Da-ju \u0dba\u0db1\u0dd4 \u0db7\u0dcf\u0dc2\u0dcf \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0daf\u0db1\u0dca\u0db1\u0dcf \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dd3\u0dba \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0d94\u0dc4\u0dd4 Ui-su\u0d9c\u0dda \u0d9a\u0dd4\u0da9\u0dcf \u0d9a\u0dbd \u0dc3\u0dd2\u0da7\u0db8 \u0dc3\u0db8\u0dd3\u0db4 \u0db8\u0dd2\u0dad\u0dd4\u0dbb\u0dd9\u0d9a\u0dd2. Jung Gi-jeon \u0dba\u0db1\u0dd4 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dc0\u0db1\u0dca\u0dad \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb Eui-ju\u0d9c\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0daf\u0d9a\u0dca\u0dc2\u0dad\u0dcf \u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0dba. Yoon Dong-ju \u0db1\u0db8\u0dca \u0d9a\u0ddc\u0dbb\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dc3\u0dcf\u0dc4\u0dd2\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dba\u0dcf \u0dc3\u0db1\u0dca\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0d9c\u0dde\u0dbb\u0dc0\u0dcf\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0dc4\u0dd0\u0dc3\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0d9a\u0dca\u0dad\u0dba.\n\nEui-ju \u0db8\u0dd9\u0db8 \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dcf\u0db8 \u0dad\u0db8 \u0db1\u0dc0 \u0d86\u0daf\u0dbb \u0d9a\u0dad\u0dcf\u0dc0\u0dda \u0da0\u0dbb\u0dd2\u0dad \u0dbd\u0dd9\u0dc3 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb, \u0d87\u0dba\u0d9c\u0dda \u0db4\u0dd4\u0daf\u0dd4\u0db8\u0dba\u0da7 \u0d91\u0db8 \u0db1\u0dc0\u0d9a\u0dad\u0dcf\u0dc0 \u0d85\u0dad\u0dd2\u0dc1\u0dba \u0da2\u0db1\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba \u0dc0\u0dd9\u0dba\u0dd2. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0d87\u0dba\u0d9c\u0dda \u0dbd\u0ddc\u0d9a\u0dd4\u0db8 \u0dc3\u0dad\u0dd4\u0dbb\u0dcf \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dad\u0db1 \u0d9c\u0dab\u0dd2\u0dad \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0db1 Ui-su \u0d87\u0dba\u0d9c\u0dda \u0dbb\u0dc4\u0dc3 \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0db1\u0dd3. \u0d94\u0dc4\u0dd4 \u0db1\u0dd2\u0dc4\u0dac\u0dc0 \u0dc3\u0dd2\u0da7\u0dd3\u0db8 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d89