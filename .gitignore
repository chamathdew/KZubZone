node_modules/
client/node_modules/
server/node_modules/

# Production build outputs
client/dist/

# Environment variables
.env
.env.*
**/.env
**/.env.*

# Local logs
*.log
client/*.log
server/*.log

# IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

